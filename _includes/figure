<figure class="{{ include.class }}">  
    {%- if include.lightbox == false -%}      
        <img src="{{ include.imagePath | relative_url }}" 
             alt="{% if include.alt %}{{ include.alt }}{% endif %}" 
             class="{% unless include.imageBorder == false %}image-border{% endunless %} {{ include.imageClass }}" 
             style="{% if include.imageStyle %}{{ include.imageStyle }}{% endif %}" />

    {%- else -%}
        <a href="{{ include.imagePath | absolute_url }}" target="_blank" rel="noopener" data-lity>
            <img src="{{ include.imagePath | relative_url }}" 
                 alt="{% if include.alt %}{{ include.alt }}{% endif %}" 
                 class="{% unless include.imageBorder == false %}image-border{% endunless %} {{ include.imageClass }}"
                 style="{% if include.imageStyle %}{{ include.imageStyle }}{% endif %}" />
        </a>        
    {%- endif -%}
    {%- if include.caption -%}
    <figcaption>
        {{ include.caption | markdownify | remove: "<p>" | remove: "</p>" }}
    </figcaption>
    {%- endif -%}
</figure>
