{"nodes": [{"id": "_squad_decisions_custom_hugo_rebuild", "label": "Custom In-Repo Hugo Rebuild", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A custom in-repo Hugo site preserves existing Markdown posts, post URLs, image paths, all images, and the current logo without adopting a third-party theme."}, {"id": "_squad_decisions_ai_review_gated_publishing", "label": "AI Review-Gated Publishing", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AI-generated posts, images, and metadata must enter through pull requests for human review and must never publish directly to the main branch."}, {"id": "_squad_decisions_accessible_motion_modernization", "label": "Accessible Motion Modernization", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The visual refresh uses progressive parallax and scroll reveal while preserving the logo and respecting prefers-reduced-motion."}, {"id": "_squad_decisions_hugo_migration_validation_gate", "label": "Hugo Migration Validation Gate", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Production cutover remains gated on migration checks, Hugo builds, and staging or preview smoke tests even after all 36 Jekyll posts are represented under content/posts."}, {"id": "_squad_decisions_vanilla_figure_lightbox", "label": "Default-On Vanilla Figure Lightbox", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A lightweight vanilla-JavaScript lightbox avoids the unused jQuery dependency required by Lity, defaults on with a per-post opt-out, and includes keyboard and focus accessibility."}, {"id": "_squad_decisions_hugo_build_blocker_resolution", "label": "Hugo Build Blocker Resolution", "file_type": "concept", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_squad_decisions_ai_article_pipeline_mvp", "label": "AI Article Pipeline MVP", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The initial pipeline runs manually in GitHub Actions, generates reviewable drafts, and defers scheduling and hosted-agent promotion until the supervised phase."}, {"id": "_squad_decisions_foundry_model_selection", "label": "Foundry Model Selection", "file_type": "concept", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_squad_decisions_direct_mvp_topology", "label": "Direct MVP Execution Topology", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Direct model calls keep the MVP simple while prompts stabilize; promotion to Foundry hosted agents is deferred."}, {"id": "_squad_decisions_least_privilege_github_app", "label": "Least-Privilege GitHub App", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The automation identity cannot self-approve pull requests, and branch protection requires Rodrigo's human approval."}, {"id": "_squad_decisions_two_lock_publishing", "label": "Two-Lock Publishing Model", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rendering requires an approved pull-request merge plus draft:false and ai.reviewed_by; merging alone does not publish."}, {"id": "_squad_decisions_topic_ledger", "label": "Per-Topic Lifecycle Ledger", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One YAML file per topic records lifecycle state, while exact keys and semantic embeddings enforce a 0.82 novelty threshold against a rebuildable cache and published content index."}, {"id": "_squad_decisions_agentic_tavily_pipeline", "label": "Agentic Tavily Discovery Pipeline", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A ReAct tool-calling loop lets the model propose searches while the orchestrator executes Tavily, keeping its credential only in GitHub Secrets and requiring no new Azure infrastructure or Python dependencies."}, {"id": "_squad_decisions_weekly_fail_closed_fanout", "label": "Weekly Fail-Closed Article Fan-Out", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A Monday 06:00 UTC run ranks all passing candidates, generates at most the configured top three, opens one draft pull request per article, and emits no pull request when any safety or budget gate fails."}, {"id": "_squad_decisions_grounded_image_policy", "label": "Grounded Article Image Policy", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Articles may use generated body images and allowlisted source images only with visible attribution, server-side URL validation, and an enforced RAI and copyright review checklist."}, {"id": "_squad_decisions_embeddings_semantic_dedup", "label": "Embeddings-Based Semantic Deduplication", "file_type": "concept", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_squad_decisions_tavily_key_rotation_gate", "label": "Tavily Key Rotation Run Gate", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The previously pasted Tavily key is treated as compromised; rotation and storage only as TAVILY_API_KEY are blocking prerequisites for the first real weekly run."}, {"id": "_squad_decisions_open_pr_dedup_gap", "label": "Open Pull Request Deduplication Gap", "file_type": "concept", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_squad_decisions_english_processing_spanish_publishing", "label": "English Processing and Spanish Publishing", "file_type": "rationale", "source_file": ".squad/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All AI reasoning and working metadata use English in a single pass, while every reader-facing field remains Spanish from Spain and image prompts remain English."}], "edges": [{"source": "_squad_decisions_ai_review_gated_publishing", "target": "_squad_decisions_two_lock_publishing", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".squad/decisions.md", "source_location": null, "weight": 1.0}, {"source": "_squad_decisions_accessible_motion_modernization", "target": "_squad_decisions_vanil