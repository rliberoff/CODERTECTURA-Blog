{"nodes": [{"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_article", "label": "Microsoft Agent Framework at Build 2026", "file_type": "document", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_microsoft_agent_framework", "label": "Microsoft Agent Framework", "file_type": "concept", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_agent_harness", "label": "Agent Harness", "file_type": "concept", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agent Harness forms the operational boundary where file access, tool approvals, and memory types make a capable agent governable; the model reasons, but the harness controls execution."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_tool_approval_strategies", "label": "Tool Approval Strategies", "file_type": "rationale", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Explicit auto-approved, conditional, and mandatory-human approval levels prevent sensitive or irreversible actions from executing solely on model initiative."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_layered_agent_memory", "label": "Layered Agent Memory", "file_type": "rationale", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Separating session, operational, preference, and externally retrieved memory avoids excessive, incorrect, or unsafe retention."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_agent_observability", "label": "Agent Observability", "file_type": "rationale", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Production operation requires reconstructing user input, context retrieval, tool selection, approvals, final output, cost, latency, and failures across the complete agent flow."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_multiagent_specialization", "label": "Multi-agent Specialization", "file_type": "rationale", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multiple agents are justified only when each has a clear one-sentence responsibility and contract; overlapping responsibilities rapidly make the system opaque."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_durable_workflows", "label": "Durable Agent Workflows", "file_type": "rationale", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Long-running processes with human waits, external calls, retries, compensations, and notifications should be modeled as durable workflows rather than one long model conversation."}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_toolapprovalpolicy", "label": "ToolApprovalPolicy", "file_type": "code", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_approvaldecision", "label": "ApprovalDecision", "file_type": "code", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_build_2026_recap", "label": "Microsoft Build 2026 Recap", "file_type": "document", "source_file": "content/posts/2026-07-01-microsoft-agent-framework-en-build-2026-como-pasar-de-un-prototipo-a-un-agente-l.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2026_07_01_microsoft_agent_framework_en_build_2026_como_pasar_de_un_prototipo_a_un_agente_l_dotnet_at_build_2026", "label": ".NET at Microsoft Build 2026", "file_type": "document", "source_file":