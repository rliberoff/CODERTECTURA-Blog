{"nodes": [{"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_article", "label": "Planning for Success with Semantic Kernel Planners", "file_type": "document", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_semantic_kernel_planners", "label": "Semantic Kernel Planners", "file_type": "concept", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Planners use AI to select and combine registered plugin functions into steps that satisfy a user goal when developers cannot enumerate every possible workflow."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_action_planner", "label": "Action Planner", "file_type": "concept", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Action Planner chooses one best-aligned function, making it suitable for intent routing and low-latency scenarios."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_sequential_planner", "label": "Sequential Planner", "file_type": "concept", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sequential Planner creates serial multi-function plans and passes each function output into the next function."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_stepwise_planner", "label": "Stepwise Planner", "file_type": "concept", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stepwise Planner dynamically explores functions and can revise its approach while solving interconnected multi-step requests."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_custom_planner", "label": "Custom Planner", "file_type": "concept", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_mrkl", "label": "Modular Reasoning, Knowledge and Language (MRKL)", "file_type": "paper", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_relevancy_threshold", "label": "Planner Relevancy Threshold", "file_type": "rationale", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Filtering functions below a relevance threshold produces more focused and efficient plans and raises the chance of successfully satisfying complex goals."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_function_descriptions", "label": "Function Descriptions as Planner Metadata", "file_type": "rationale", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Planners identify relevant functions and parameters from their descriptions, so descriptions should be verbose, concrete, complete, and unambiguous."}, {"id": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_planner_tradeoffs", "label": "Planner Performance, Cost, and Reliability Tradeoffs", "file_type": "rationale", "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Planners are slow, make multiple costly LLM calls, and can generate defective plans because generation is stochastic; exclusions, retries, error handling, and precise descriptions mitigate these risks."}], "edges": [{"source": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_article", "target": "content_posts_2023_11_13_nos_vemos_en_la_net_core_conf_2023_madrid_announcement", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "weight": 1.0}, {"source": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_article", "target": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_semantic_kernel_planners", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "content/posts/2023-11-20-netcoreconf-2023-madrid-planificando-para-el-exito.md", "source_location": null, "weight": 1.0}, {"source": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_action_planner", "target": "content_posts_2023_11_20_netcoreconf_2023_madrid_planificando_para_el_exito_semantic_kernel_planners", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "sou